{
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "max_open_trades": 6,
    "stake_currency": "USDT",
    "stake_amount": 100,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 2000,
    "cancel_open_orders_on_exit": true,

    "exchange": {
        "name": "bybit",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "SOL/USDT:USDT",
            "BNB/USDT:USDT",
            "XRP/USDT:USDT",
            "DOGE/USDT:USDT",
            "ADA/USDT:USDT",
            "AVAX/USDT:USDT",
            "LINK/USDT:USDT",
            "DOT/USDT:USDT",
            "NEAR/USDT:USDT",
            "UNI/USDT:USDT",
            "PEPE/USDT:USDT",
            "INJ/USDT:USDT",
            "ARB/USDT:USDT",
            "OP/USDT:USDT",
            "ZEC/USDT:USDT",
            "FIL/USDT:USDT",
            "AAVE/USDT:USDT",
            "LTC/USDT:USDT"
        ],
        "pair_blacklist": [
            "BUSD/USDT:USDT"
        ]
    },

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },

    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },

    "leverage": {
        "default": 5
    },

    "telegram": {
        "enabled": true,
        "token": "${TELEGRAM_TOKEN}",
        "chat_id": "${TELEGRAM_CHAT_ID}",
        "notification_settings": {
            "status": "on",
            "warning": "on",
            "startup": "on",
            "entry": "on",
            "entry_fill": "on",
            "exit": "on",
            "exit_fill": "on",
            "exit_cancel": "on",
            "protection_trigger": "on",
            "protection_trigger_global": "on"
        }
    },

    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8081,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "apex-freqtrade-2026",
        "CORS_origins": ["*"],
        "username": "apex",
        "password": "apex2026"
    },

    "bot_name": "APEX-FreqTrade",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    }
}
